# Gatsby build (Netlify / local)
GATSBY_SANITY_PROJECT_ID=seqw2iwb
GATSBY_SANITY_DATASET=production
# Read token: optional for public datasets; required for private drafts
SANITY_READ_TOKEN=

# Sanity Studio (pasta studio/) — pode ser o mesmo project/dataset
SANITY_STUDIO_PROJECT_ID=seqw2iwb
SANITY_STUDIO_DATASET=production
